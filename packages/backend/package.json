    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
