// Store-CRM — Prisma Schema
// All core entities for the retail CRM system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum InteractionType {
  VISIT
  CALL
  PURCHASE
  COMPLAINT
}

// ── Models ───────────────────────────────────────

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  customers    Customer[]
  tags         Tag[]
  products     Product[]
  interactions Interaction[]
  sales        Sale[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(STAFF)
  storeId      String?
  createdAt    DateTime @default(now())

  store        Store?        @relation(fields: [storeId], references: [id])
  interactions Interaction[]
  sales        Sale[]

  @@index([storeId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  storeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id])
  tags         Tag[]         @relation("CustomerTags")
  interactions Interaction[]
  sales        Sale[]

  @@index([storeId])
  @@index([storeId, email])
  @@index([phone])
  @@index([name])
}

model Tag {
  id      String @id @default(cuid())
  name    String
  color   String
  storeId String

  store     Store      @relation(fields: [storeId], references: [id])
  customers Customer[] @relation("CustomerTags")

  @@index([storeId])
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(12, 2)
  sku       String?
  category  String?
  storeId   String
  createdAt DateTime @default(now())

  store               Store                @relation(fields: [storeId], references: [id])
  saleItems           SaleItem[]
  interactionProducts InteractionProduct[]

  @@index([storeId])
}

model Interaction {
  id         String          @id @default(cuid())
  type       InteractionType
  date       DateTime
  notes      String?
  customerId String
  userId     String
  storeId    String
  createdAt  DateTime        @default(now())

  store    Store                @relation(fields: [storeId], references: [id])
  user     User                 @relation(fields: [userId], references: [id])
  customer Customer             @relation(fields: [customerId], references: [id])
  products InteractionProduct[]

  @@index([storeId])
  @@index([customerId])
}

model Sale {
  id          String   @id @default(cuid())
  totalAmount Decimal  @db.Decimal(12, 2)
  date        DateTime
  customerId  String
  userId      String
  storeId     String
  createdAt   DateTime @default(now())

  customer Customer   @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  store    Store      @relation(fields: [storeId], references: [id])
  items    SaleItem[]

  @@index([storeId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model InteractionProduct {
  interactionId String
  productId     String

  interaction Interaction @relation(fields: [interactionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@id([interactionId, productId])
}
